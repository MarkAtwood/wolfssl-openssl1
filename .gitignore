# ── Build artifacts ─────────────────────────────────────────────────────────
*.o
*.lo
*.la
*.a
*.so
*.so.*
*.dylib
*.d

# ── OpenSSL build outputs ────────────────────────────────────────────────────
openssl/apps/openssl
openssl/apps/openssl.exe
openssl/libcrypto*
openssl/libssl*
openssl/fuzz/*-test
openssl/test/[a-z]*          # test binaries (not .c source)
openssl/*.map
openssl/configdata.pm
openssl/providers/
# Makefile is generated by ./Configure but we commit our modified version
# (see openssl/Makefile — do not re-run ./Configure without re-applying patches)

# ── wolfSSL build outputs ────────────────────────────────────────────────────
wolfssl/src/.libs/
wolfssl/.libs/
wolfssl/wolfssl.pc
wolfssl/stamp-h1
wolfssl/config.log
wolfssl/config.status
wolfssl/libtool
wolfssl/Makefile
wolfssl/src/Makefile

# ── shim build outputs ──────────────────────────────────────────────────────
shim/src/**/*.o
shim/lib/*.a

# ── Editor / OS junk ────────────────────────────────────────────────────────
*.bak
*~
.DS_Store
*.swp
*.swo
\#*\#

# ── Audit scratch (keep the .md reports, ignore interim files) ───────────────
shim/audit/*.txt
shim/audit/*_status.md
