diff --git a/test/ssl-tests/31-wolfshim-alert-delivery.conf.in b/test/ssl-tests/31-wolfshim-alert-delivery.conf.in
new file mode 100644
index 00000000..d20e2e0c
--- /dev/null
+++ b/test/ssl-tests/31-wolfshim-alert-delivery.conf.in
@@ -0,0 +1,49 @@
+# -*- mode: perl; -*-
+# Copyright 2026 The OpenSSL Project Authors. All Rights Reserved.
+#
+# Licensed under the OpenSSL license (the "License").  You may not use
+# this file except in compliance with the License.  You can obtain a copy
+# in the file LICENSE in the source distribution or at
+# https://www.openssl.org/source/license.html
+
+## Tests for wolfshim rec_layer_s3.c alert-delivery fix.
+##
+## Before the fix, a fatal alert sent by the client before TLS version
+## negotiation completed was silently dropped by the server because the
+## TLS_ANY_VERSION guard in ssl3_read_bytes() ran *before* the alert
+## dispatch block, causing ssl_read_bytes() to return
+## SSL_AD_UNEXPECTED_MESSAGE without ever delivering the alert to the
+## info callback.
+##
+## The fix moves the guard below the SSL3_RT_ALERT dispatch so that:
+##   - The info callback (SSL_CB_READ_ALERT) fires correctly.
+##   - server_ex_data.alert_received is populated.
+##   - ExpectedClientAlertReceived assertions pass.
+
+package ssltests;
+
+our @tests = (
+
+    # Client supports only TLS 1.2; server supports only TLS 1.1.
+    # Client proposes TLS 1.2; server responds with ServerHello indicating
+    # TLS 1.1.  Client rejects the downgrade and sends a protocol_version
+    # alert.  With the fix, the server's info callback receives this alert
+    # before the TLS_ANY_VERSION guard can discard it.
+    {
+        name => "client-protocol-version-alert-delivered-to-server",
+        server => {
+            "MinProtocol" => "TLSv1.1",
+            "MaxProtocol" => "TLSv1.1",
+        },
+        client => {
+            "MinProtocol" => "TLSv1.2",
+            "MaxProtocol" => "TLSv1.2",
+        },
+        test => {
+            "ExpectedResult"               => "ClientFail",
+            "ExpectedClientAlert"          => "ProtocolVersion",
+            "ExpectedClientAlertReceived"  => "ProtocolVersion",
+        },
+    },
+
+);
