+# Generated with generate_ssl_tests.pl
+
+num_tests = 1
+
+test-0 = 0-client-protocol-version-alert-delivered-to-server
+# ===========================================================
+
+[0-client-protocol-version-alert-delivered-to-server]
+ssl_conf = 0-client-protocol-version-alert-delivered-to-server-ssl
+
+[0-client-protocol-version-alert-delivered-to-server-ssl]
+server = 0-client-protocol-version-alert-delivered-to-server-server
+client = 0-client-protocol-version-alert-delivered-to-server-client
+
+[0-client-protocol-version-alert-delivered-to-server-server]
+Certificate = ${ENV::TEST_CERTS_DIR}/servercert.pem
+CipherString = DEFAULT
+MaxProtocol = TLSv1.1
+MinProtocol = TLSv1.1
+PrivateKey = ${ENV::TEST_CERTS_DIR}/serverkey.pem
+
+[0-client-protocol-version-alert-delivered-to-server-client]
+CipherString = DEFAULT
+MaxProtocol = TLSv1.2
+MinProtocol = TLSv1.2
+VerifyCAFile = ${ENV::TEST_CERTS_DIR}/rootcert.pem
+VerifyMode = Peer
+
+[test-0]
+ExpectedClientAlert = ProtocolVersion
+ExpectedClientAlertReceived = ProtocolVersion
+ExpectedResult = ClientFail
+
+
